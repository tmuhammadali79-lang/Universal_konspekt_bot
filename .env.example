# Telegram Bot Token (from @BotFather)
BOT_TOKEN=your_bot_token_here

# OpenAI API Key
OPENAI_API_KEY=your_openai_api_key_here

# Admin user IDs (comma-separated)
ADMIN_IDS=123456789

# Database path
DB_PATH=data/bot.db

# Limits (free tier)
FREE_DAILY_REQUESTS=3
FREE_DAILY_MINUTES=10
REFERRAL_BONUS_MINUTES=5

# Telegram Stars premium price
PREMIUM_STARS_PRICE=100

# Group auto-summary: minimum voice duration (seconds)
GROUP_VOICE_MIN_DURATION=30
